<div id="form_response">
  <div class="w-full max-w-lg text-center">
    <div class="rounded-xl bg-green-50 border border-green-200 px-6 py-5">
      <p class="text-lg font-semibold text-green-800">Thank you! We'll reach out within 48 hours.</p>
      <button data-cal-link="neshaz/litetracker" data-cal-namespace="litetracker" data-cal-config='{"layout":"month_view"}' class="inline-flex items-center gap-2 mt-3 rounded-xl bg-black px-6 py-3 text-base font-semibold text-white shadow-xs hover:bg-black/80 cursor-pointer" data-umami-event="cta-book-migration" data-umami-event-location="pt-alternative-hero">
        <%= local_assigns.fetch(:button_text, "Book a migration now") %> <span aria-hidden="true">&rightarrow;</span>
      </button>
    </div>
  </div>
</div>
