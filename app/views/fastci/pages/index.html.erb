            </li>
            <li class="text-white flex text-lg font-normal items-start">
              <svg class="mr-2 mt-1 h-5 w-5" viewBox="0 0 16 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M15.875 1.75C15.875 2.06641 15.7344 2.34766 15.5234 2.55859L6.52344 11.5586C6.3125 11.7695 6.03125 11.875 5.75 11.875C5.43359 11.875 5.15234 11.7695 4.94141 11.5586L0.441406 7.05859C0.230469 6.84766 0.125 6.56641 0.125 6.25C0.125 5.61719 0.617188 5.125 1.25 5.125C1.53125 5.125 1.8125 5.26562 2.02344 5.47656L5.75 9.16797L13.9414 0.976562C14.1523 0.765625 14.4336 0.625 14.75 0.625C15.3477 0.625 15.875 1.11719 15.875 1.75Z" fill="#22C55E"/>
              </svg>
