            </li>
          </ul>
          <div class="mt-10 flex justify-center sm:justify-start items-center gap-x-6">
            <a href="https://app.fast.ci/auth/github" class="rounded-full bg-<%= @button_color %> px-4 py-2 sm:px-8 sm:py-4 text-base text-white shadow-sm hover:bg-<%= @button_hover %>">Free Trial Month</a>
            <a href="/pricing" class="rounded-full px-4 py-2 sm:px-8 sm:py-4 text-base text-white shadow-sm hover:bg-<%= @button_color %> shadow-sm ring-1 ring-inset ring-white hover:ring-0">View Pricing</a>
          </div>
        </div>
        <div class="relative mx-auto xs:mt-24 lg:mt-16 flex justify-center max-w-2xl sm:mt-24 lg:ml-10 lg:mr-0 lg:mt-0 lg:max-w-none lg:flex-none xl:ml-32">
