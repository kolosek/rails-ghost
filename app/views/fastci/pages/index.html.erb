    <div class="overflow-hidden">
      <div class="mx-auto max-w-7xl pt-24 sm:pt-32 pb-16 border-b border-black/10">
        <p class="uppercase text-black text-base text-center font-semibold">Supported Programming Languages</p>
        <div class="px-6">
          <div class="mx-auto lg:mx-0">
            <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-y-8 sm:h-16">
              <%=image_tag "fastci/logo-elixir.png", class: 'max-h-10 xs:max-h-16', alt: "Elixir"%>
              <%=image_tag "fastci/logo-ruby.png", class: 'max-h-10 xs:max-h-16', alt: "Ruby"%>
              <%=image_tag "fastci/logo-rails.png", class: 'max-h-10 xs:max-h-16', alt: "Rails"%>
              <%=image_tag "fastci/logo-node.png", class: 'max-h-10 xs:max-h-16', alt: "Node"%>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

