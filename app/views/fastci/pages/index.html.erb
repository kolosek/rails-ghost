          <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-x-6 gap-y-2">
            <a href="https://app.fast.ci/auth/github" class="rounded-full bg-<%= @button_color %> w-48 px-8 py-4 text-base text-white shadow-sm hover:bg-<%= @button_hover %>">Free Trial Month</a>
            <a href="/pricing" class="rounded-full px-8 py-4 text-base text-black hover:text-white shadow-sm hover:bg-<%= @button_color %> shadow-sm ring-1 ring-inset ring-black hover:ring-0 hidden sm:block">Learn more about features</a>
            <a href="/pricing" class="rounded-full w-48 px-8 py-4 text-base text-black hover:text-white shadow-sm hover:bg-<%= @button_color %> shadow-sm ring-1 ring-inset ring-black hover:ring-0 sm:hidden">View Pricing</a>
          </div>
        </div>
      </div>
      <div class="flow-root">
        <div class="mx-2 md:mx-auto -mb-10 sm:-mb-16 md:-mb-24 hidden sm:block">
          <%=image_tag "fastci/feature-section.png", alt: "App screenshot", class: "w-full h-auto"%>
        </div>
        <div class="mx-2 mb-6 sm:hidden">
          <ul role="list" class="space-y-3">
            <li class="overflow-hidden flex items-center rounded-lg bg-white px-6 py-8 ring-1 ring-inset ring-slate-200 shadow">
              <%=image_tag "fastci/code-quality.svg", class: ""%>
              <span class="ml-2.5 text-lg font-light">Code Quality Assurance</span>
            </li>
            <li class="overflow-hidden flex items-center rounded-lg bg-white px-6 py-8 ring-1 ring-inset ring-slate-200 shadow">
              <%=image_tag "fastci/coverage-check.svg", class: ""%>
              <span class="ml-2.5 text-lg font-light">Test Coverage Check.</span>
            </li>
            <li class="overflow-hidden flex items-center rounded-lg bg-white px-6 py-8 ring-1 ring-inset ring-slate-200 shadow">
              <%=image_tag "fastci/code-security.svg", class: ""%>
              <span class="ml-2.5 text-lg font-light">Checks Code Security</span>
            </li>
            <li class="overflow-hidden flex items-center rounded-lg bg-white px-6 py-8 ring-1 ring-inset ring-slate-200 shadow">
              <%=image_tag "fastci/quick-feedback.svg", class: ""%>
              <span class="ml-2.5 text-lg font-light">A quick feedback loop</span>
            </li>
            <li class="overflow-hidden flex items-center rounded-lg bg-white px-6 py-8 ring-1 ring-inset ring-slate-200 shadow">
              <%=image_tag "fastci/code-solving.svg", class: ""%>
              <span class="ml-2.5 text-lg font-light">Efficient code-solving</span>
            </li>
            <li class="overflow-hidden flex items-center rounded-lg bg-white px-6 py-8 ring-1 ring-inset ring-slate-200 shadow">
              <%=image_tag "fastci/simplicity-ux.svg", class: ""%>
              <span class="ml-2.5 text-lg font-light">Simplicity in UX</span>
            </li>
          </ul>
        </div>
        <div class="relative mx-2 lg:mx-auto bg-slate-900 rounded-2xl max-w-6xl">
          <div class="relative mx-auto px-2 md:px-6 py-4 lg:py-10 lg:px-12">
            <dl class="mx-auto grid lg:gap-x-8 gap-y-2 text-white sm:gap-y-16 lg:mx-0 lg:max-w-none grid-cols-1 sm:grid-cols-4">
              <div class="flex flex-col items-center gap-y-1 md:gap-y-3 lg:pl-6">
                <dt class="text-base/6 text-center">Tests Run</dt>
                <dd class="order-first text-3xl font-semibold tracking-tight">1,200,456</dd>
                <div class="border-t border-white/15 my-4 w-32 sm:hidden"></div>
              </div>
              <div class="flex flex-col items-center gap-y-1 md:gap-y-3 sm:border-l border-white/10 lg:pl-6">
                <dt class="text-base/6 text-center">Minutes Saved</dt>
                <dd class="order-first text-3xl font-semibold tracking-tight">12,200,456</dd>
                <div class="border-t border-white/15 my-4 w-32 sm:hidden"></div>
              </div>
              <div class="flex flex-col items-center gap-y-1 md:gap-y-3 sm:border-l xs:border-white/10 lg:pl-6">
                <dt class="text-base/6 text-center">Supporting huge projects</dt>
                <dd class="order-first text-3xl font-semibold tracking-tight">1m+ LOC</dd>
                <div class="border-t border-white/15 my-4 w-32 sm:hidden"></div>
              </div>
              <div class="flex flex-col items-center gap-y-1 md:gap-y-3 sm:border-l border-white/10 lg:pl-6">
                <dt class="text-base/6 text-center">Uptime guarantee</dt>
                <dd class="order-first text-3xl font-semibold tracking-tight">99.9%</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>
  
