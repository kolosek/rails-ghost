            <%=image_tag "fastci/hero-image.png", class: "relative z-[1] mt-16"%>
            <%=image_tag "fastci/mask-print-white.svg", class: "absolute scale-75 xs:scale-100 -left-6 bottom-8 xs:-left-9 xs:bottom-24"%>
            <%=image_tag "fastci/mask-print-white.svg", class: "absolute scale-75 xs:scale-100 right-10 top-9 xs:right-20"%>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="bg-gray-950">
    <div class="mx-auto py-8 max-w-7xl sm:pb-28 sm:pt-[4.5rem]">
      <h2 class="text-center text-lg font-semibold leading-8 text-white/50">TRUSTED BY</h2>
      <div class="mx-auto mt-9 grid max-w-lg grid-cols-4 items-center gap-x-8 gap-y-10 sm:max-w-xl sm:gap-x-10 lg:-mx-12 lg:max-w-none opacity-50">
        <%=image_tag "fastci/logo-oschool-white.svg", class: "col-span-2 max-h-8 xs:max-h-10 w-full object-contain sm:col-span-1", alt: "Agendaedu", width: "158", height: "48"%>
        <%=image_tag "fastci/logo-nomad-white.svg", class: "col-span-2 max-h-8 xs:max-h-10 w-full object-contain sm:col-span-1", alt: "OSchool", width: "158", height: "48"%>
        <%=image_tag "fastci/logo-eb-white.svg", class: "col-span-2 max-h-8 xs:max-h-10 w-full object-contain sm:col-span-1", alt: "ElectionBuddy"%>
        <%=image_tag "fastci/logo-husky-white.svg", class: "col-span-2 max-h-8 xs:max-h-10 w-full object-contain sm:col-span-1", alt: "Husky"%>
      </div>
    </div>
  </section>
  <section id="features-section" class="bg-zinc-100 -mb-16 scroll-mt-20">
    <div class="mx-auto max-w-7xl overflow-hidden">
      <div class="px-6 pt-12 pb-10 sm:py-16 sm:px-6 lg:px-8">
