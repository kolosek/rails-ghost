<script type="text/javascript">
  $(document).ready(function () {
    //Sticky
    console.log('sticky loaded');
    var stickyNavTop = $('#secondary_nav').offset().top - 160;
    var topHeight = $('header nav').outerHeight();

    var stickyNav = function(){
      var scrollTop = $(window).scrollTop();

      if (scrollTop >= stickyNavTop) {
        $('#secondary_nav').css({
          'position': 'fixed',
          'top': topHeight+'px'
        }).addClass('bg-white border-t border-black/10');;
      } else {
        $('#secondary_nav').css({
          'position': 'relative',
          'top': '0'
        }).removeClass('bg-white border-t border-black/10');
      }
    };

    stickyNav();

    $(window).scroll(function() {
        stickyNav();
    });
  });
</script>
