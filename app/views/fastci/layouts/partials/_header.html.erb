<header class="relative z-40 sticky top-0 bg-white border-b border-black/10">
  <nav class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8" aria-label="Global">
    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5 flex items-center">
        <%=image_tag @page_logo ||= 'fastci/logo-fast.svg', class: "h-8", alt: "logo" %>
        <span class="ml-2 text-2xl font-semibold">FastCI</span>
      </a>
    </div>
    <div class="flex lg:hidden">
      <button id="mobileMenuButton" type="button" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-400">
        <span class="sr-only">Open main menu</span>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:items-center lg:gap-x-12">
      <a href="/features" class="text-base leading-normal text-black hover:[text-shadow:_1px_0_0_currentColor]">Features</a>
      <a href="#" class="text-base leading-normal text-black hover:[text-shadow:_1px_0_0_currentColor]">Committer Analysis</a>
      <a href="/pricing" class="text-base leading-normal text-black hover:[text-shadow:_1px_0_0_currentColor]">Pricing</a>
      <div class="relative">
        <button type="button" id="dropdownButton" class="flex items-center gap-x-1 text-base leading-normal text-black hover:[text-shadow:_1px_0_0_currentColor]" aria-expanded="false">
          Developers
          <svg class="h-5 w-5 flex-none" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
            <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </button>
        <div id="flyoutMenu" class="absolute -left-10 top-full w-screen max-w-44 z-40 mt-6 hidden">
          <div class="group relative flex gap-x-6 text-sm leading-5 rounded-t-md border border-b-0 border-black/15 bg-white hover:[text-shadow:_1px_0_0_currentColor]">
            <div class="flex-auto">
              <a href="#" class="p-4 block text-black">
                Support
              </a>
            </div>
          </div>
          <div class="group relative flex gap-x-6 text-sm leading-5 border border-b-0 border-black/15 bg-white hover:[text-shadow:_1px_0_0_currentColor]">
            <div class="flex-auto">
              <a href="#" class="p-4 block text-black">
                Documentations
              </a>
            </div>
          </div>
          <div class="group relative flex gap-x-6 text-sm leading-5 rounded-b-md border border-black/15 bg-white hover:[text-shadow:_1px_0_0_currentColor]">
            <div class="flex-auto">
              <a href="/blog" class="p-4 block text-black">
                Blog
              </a>
            </div>
          </div>
        </div>
      </div>
      <a href="https://calendly.com/rubyci" class="border-b border-zinc-700 py-1 mx-3 px-1 leading-normal text-black hover:[box-shadow:_0_-2px_0_0_inset_currentColor] hover:[text-shadow:_1px_0_0_currentColor]">Book A Call</a>
    </div>
    <div class="hidden lg:flex lg:flex-1 lg:justify-end">
      <a href="https://app.fast.ci/auth/github" class="inline-flex items-center gap-x-2 rounded-full px-4 py-1 text-base text-black shadow-sm ring-1 ring-inset ring-black hover:[text-shadow:_1px_0_0_currentColor]">
        Login with
        <%=image_tag "fastci/github.svg", class: "-mr-0.5 h-5 w-5", alt: "GitHub"%>
      </a>
    </div>
  </nav>
  <!-- Mobile menu, show/hide based on menu open state. -->
  <div id="mobileMenu" class="lg:hidden hidden" role="dialog" aria-modal="true">
    <!-- Background backdrop, show/hide based on slide-over state. -->
    <div class="fixed inset-0 z-40"></div>
    <div class="fixed inset-y-0 right-0 z-40 w-full overflow-y-auto bg-white px-6 py-6 sm:max-w-sm sm:ring-1 sm:ring-white/10">
      <div class="flex items-center justify-between">
        <a href="/" class="-m-1.5 p-1.5">
          <span class="sr-only">Your Company</span>
          <%=image_tag "fastci/logo-green.svg", class: "h-8 w-auto" %>
        </a>
        <button id="closeMobileMenu" type="button" class="-m-2.5 rounded-md p-2.5 text-gray-400">
          <span class="sr-only">Close menu</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="mt-6 flow-root">
        <div class="-my-6 divide-y divide-gray-500/25">
          <div class="space-y-2 py-6">
            <a href="/features" class="-mx-3 block rounded-lg px-3 py-2 text-base leading-7 text-black hover:bg-gray-200">Features</a>
            <a href="#" class="-mx-3 block rounded-lg px-3 py-2 text-base leading-7 text-black hover:bg-gray-200">Committer Analysis</a>
            <a href="/pricing" class="-mx-3 block rounded-lg px-3 py-2 text-base leading-7 text-black hover:bg-gray-200">Pricing</a>
            <div class="-mx-3">
              <button id="dropdownSubMenuButton" type="button" class="flex w-full items-center justify-between rounded-lg py-2 pl-3 pr-3.5 text-base leading-7 text-black hover:bg-gray-200" aria-controls="disclosure-1" aria-expanded="false">
                Developers
                <svg id="dropdownSubMenuIcon" class="h-5 w-5 flex-none" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                  <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                </svg>
              </button>
              <div class="mt-2 space-y-2 hidden" id="disclosure-1">
                <a href="#" class="block rounded-lg py-2 pl-6 pr-3 text-sm leading-7 text-black hover:bg-gray-200">Support</a>
                <a href="#" class="block rounded-lg py-2 pl-6 pr-3 text-sm leading-7 text-black hover:bg-gray-200">Documentations</a>
                <a href="/blog" class="block rounded-lg py-2 pl-6 pr-3 text-sm leading-7 text-black hover:bg-gray-200">Blog</a>
              </div>
            </div>
            <a href="https://calendly.com/rubyci" class="-mx-3 block rounded-lg px-3 py-2 text-base leading-7 text-black hover:bg-gray-200">Book A Call</a>
          </div>
          <div class="py-6">
            <a href="https://app.fast.ci/auth/github" class="-mx-3 block rounded-lg px-3 py-2.5 text-base leading-7 text-black hover:bg-gray-200">Log in</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
